<Window x:Class="ArchiveModification.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="杀戮尖塔2 存档修改工具"
        Height="720"
        Width="960"
        MinHeight="600"
        MinWidth="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 存档操作 -->
        <GroupBox Grid.Row="0" Header="存档操作" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Row="0" Grid.Column="0" Content="打开存档" Width="100" Margin="0,0,8,0" Click="OpenSave_Click"/>
                <Button Grid.Row="0" Grid.Column="1" Content="保存存档" Width="100" Margin="0,0,12,0" Click="SaveSave_Click"/>
                <Button Grid.Row="0" Grid.Column="2" x:Name="SwitchPlayerBtn" Content="切换玩家" Width="100" Margin="0,0,12,0" Click="SwitchPlayer_Click" Visibility="Collapsed"/>
                <TextBlock Grid.Row="0" Grid.Column="3"
                           x:Name="FilePathText"
                           VerticalAlignment="Center"
                           Text="未打开存档"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, ElementName=FilePathText}"/>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="4"
                           x:Name="PlayerInfoText"
                           Margin="0,6,0,0"
                           FontWeight="Bold"
                           Visibility="Collapsed"/>
            </Grid>
        </GroupBox>

        <!-- 玩家属性 -->
        <GroupBox Grid.Row="1" Header="玩家属性" Padding="10" Margin="0,0,0,10">
            <Grid IsEnabled="False" x:Name="PlayerPropertiesPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="当前生命：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="CurrentHpBox" Width="120"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="最大生命：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxHpBox" Width="120"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="金币：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="GoldBox" Width="120"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="每回合费用：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxEnergyBox" Width="120"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="最大药水栏位：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxPotionSlotBox" Width="120"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="稀有卡牌概率加成：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="CardRarityOddsBox" Width="120"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="药水奖励概率加成：" Width="220" VerticalAlignment="Center"/>
                    <TextBox x:Name="PotionRewardOddsBox" Width="120"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 卡牌 / 遗物 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="卡牌 (deck)" Padding="8">
                <Grid IsEnabled="False" x:Name="DeckPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="DeckList"
                             Grid.Row="0"
                             DisplayMemberPath="DisplayText"
                             SelectionMode="Single"
                             FontFamily="Consolas"
                             MouseDoubleClick="DeckList_MouseDoubleClick"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="ToggleDisplayModeBtn" Content="切换显示" Width="72" Margin="0,0,8,0" Click="ToggleDisplayMode_Click"/>
                        <Button x:Name="UpgradeAllBtn" Content="一键升级" Width="72" Margin="0,0,8,0" Click="UpgradeAll_Click"/>
                        <Button Content="添加" Width="72" Margin="0,0,8,0" Click="AddDeckItem_Click"/>
                        <Button Content="删除" Width="72" Click="DeleteDeckItem_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="遗物 (relics)" Padding="8">
                <Grid IsEnabled="False" x:Name="RelicsPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="RelicsList"
                             Grid.Row="0"
                             DisplayMemberPath="DisplayText"
                             SelectionMode="Single"
                             FontFamily="Consolas"
                             MouseDoubleClick="RelicsList_MouseDoubleClick"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="ToggleRelicDisplayModeBtn" Content="切换显示" Width="72" Margin="0,0,8,0" Click="ToggleRelicDisplayMode_Click"/>
                        <Button Content="添加" Width="72" Margin="0,0,8,0" Click="AddRelicItem_Click"/>
                        <Button Content="图片添加" Width="80" Margin="0,0,8,0" Click="AddRelicByImage_Click"/>
                        <Button Content="删除" Width="72" Click="DeleteRelicItem_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
