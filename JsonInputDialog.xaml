<Window x:Class="ArchiveModification.JsonInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入 JSON"
        Height="320"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="240"
        MinWidth="400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="请输入完整的 JSON 对象：" Margin="0,0,0,8" TextWrapping="Wrap"/>
        <TextBox x:Name="JsonTextBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 TextWrapping="NoWrap"/>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Stretch"
                    Margin="0,12,0,0">
            <Button x:Name="UpgradeButton"
                    Content="一键升级"
                    Width="80"
                    Visibility="Collapsed"
                    Click="Upgrade_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="确定" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
                <Button Content="取消" Width="80" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
